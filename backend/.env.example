# ═══════════════════════════════════════════════════
# BuildBuddy MVP — Backend Environment
# ALL FREE — no paid services required
# ═══════════════════════════════════════════════════

# Your wallet private key (exports from MetaMask)
# Fund it with free MON from https://faucet.monad.xyz
ORACLE_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Free Monad testnet RPC
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Contract addresses (you get these after deploying with Foundry)
REGISTRY_CONTRACT_ADDRESS=0xDEPLOYED_ADDRESS
BOUNTYGATE_CONTRACT_ADDRESS=0xDEPLOYED_ADDRESS

# API key (make up any string — used by MCP client to auth)
API_KEYS=my-dev-key

# Server port
PORT=3001
